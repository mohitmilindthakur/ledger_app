rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Replace REPLACE_WITH_LOWERCASE_EMAIL with the same mailbox you use for
    // Google sign-in, all lowercase (Gmail treats addresses as case-insensitive,
    // but the token "email" claim is usually lowercase).
    //
    // This file does NOT apply until you Publish:
    // Firebase Console → Firestore Database → Rules → Publish
    // (same project as VITE_FIREBASE_PROJECT_ID in .env)

    match /transactions/{transactionId} {
      allow read, write: if request.auth != null
        && request.auth.token.get("email", "").lower()
          == "mohitmilindthakur@gmail.com";
    }
  }
}
