# Copy this file to ".env" in the same folder as package.json.
# Use the Web app config from Firebase Console → Project settings → Your apps.
# No quotes around values (or the quotes become part of the key and break Auth).
# After editing .env, stop and restart: npm run dev
#
# Firebase Auth (required for Google sign-in):
# Console → Build → Authentication → Get started → Sign-in method → Google → Enable.
# If you see auth/configuration-not-found, Authentication is usually not enabled yet.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Only this Google account may use the app (must match Firestore rules email).
VITE_ALLOWED_EMAIL=
